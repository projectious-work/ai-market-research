#!/usr/bin/env bash
# Generated by `aibox apply` — do NOT edit.
# Show a confirmation menu listing the open apps that will be killed by
# a layout switch, then dispatch to aibox-tmux-switch-layout on confirm.
#
# Usage: aibox-tmux-confirm-and-switch <layout-name>
#
# When the env var AIBOX_LAYOUT_CONFIRM is set to "false" the
# confirmation step is skipped and the switch runs directly. (Bound to
# the `customization.tmux.layout_switch.confirm` aibox.toml field.)

set -euo pipefail

# Route bare `tmux …` calls through the project's configured socket so
# the helper works both from inside a tmux run-shell (TMUX already set)
# and from out-of-band invocations (custom AIBOX_TMUX_SOCKET, e2e
# drivers). See aibox-tmux-switch-layout for the same pattern.
socket="${AIBOX_TMUX_SOCKET:-$HOME/.tmux/aibox.sock}"
tmux() { command tmux -S "$socket" "$@"; }

layout="${1:-}"
if [[ -z "$layout" ]]; then
    tmux display-message "missing layout name"
    exit 1
fi

session="$(tmux display-message -p '#S')"

# Skip confirmation when explicitly disabled.
if [[ "${AIBOX_LAYOUT_CONFIRM:-true}" == "false" ]]; then
    exec aibox-tmux-switch-layout "$layout"
fi

# Enumerate the currently-running TUI commands across all panes in the
# session. Filter out interactive shells (bash/zsh/fish) and the
# placeholder window. Deduplicate while preserving display order.
apps=$(tmux list-panes -t "$session" -a -F '#{pane_current_command}' \
    | grep -Ev '^(bash|zsh|fish|sh|sleep)$' \
    | awk '!seen[$0]++' \
    | paste -sd, -)
[[ -z "$apps" ]] && apps="(only shells)"

# Build a display-menu with the impacted apps in the Yes line.
tmux display-menu -T "#[align=centre]Rebuild as ${layout}" -x C -y C \
    "Yes — kill: ${apps} and rebuild" y "run-shell 'aibox-tmux-switch-layout ${layout}'" \
    "" \
    "No — cancel" n ""
