#!/usr/bin/env bash
# Generated by `aibox apply` — do NOT edit.
# Categorized tmux keybinding reference.  Invoked by: prefix + ?
#
# MAINTENANCE NOTE: this script is a static curated list.  When adding new
# prefix bindings to DEFAULT_TMUX_CONF (cli/src/tmux/status.rs), also add a
# row here so the two stay in sync.  The bind-key -N descriptions are the
# canonical source of truth; this file is the user-visible rendering.

BOLD="\033[1m"
DIM="\033[2m"
RESET="\033[0m"
ACCENT="\033[38;5;214m"   # amber — matches aibox default accent
MUTED="\033[38;5;244m"
SEP="${MUTED}─────────────────────────────────────────────────────────────────────────────${RESET}"

hdr() { printf "\n${ACCENT}${BOLD}  %-77s${RESET}\n" "$1"; printf "%b\n" "$SEP"; }
row() {
  # row <key> <desc> [<key2> <desc2>]
  local k1="$1" d1="$2" k2="${3:-}" d2="${4:-}"
  printf "  ${BOLD}%-12s${RESET}  %-28s" "$k1" "$d1"
  if [[ -n "$k2" ]]; then
    printf "  ${BOLD}%-12s${RESET}  %s" "$k2" "$d2"
  fi
  printf "\n"
}
blank() { echo; }

cat <<'HEADER'

  ╔══════════════════════════════════════════════════════════════════════════════╗
  ║         aibox  —  tmux keybinding reference         (prefix = Ctrl+g)       ║
  ╚══════════════════════════════════════════════════════════════════════════════╝
HEADER

hdr "Panes"
row "prefix h/j/k/l"  "Navigate left/down/up/right"  "prefix r"    "Split pane right"
row "prefix d"        "Split pane down"               "prefix f/z"  "Zoom / toggle zoom"
row "prefix x"        "Kill pane"

hdr "Windows"
row "prefix c"        "New window"                    "prefix n/p"  "Next / prev window"
row "prefix 1-9"      "Jump to window N"              "prefix ,"    "Rename window"
row "prefix g"        "Jump to lazygit window"        "prefix s"    "Jump to shell window"

hdr "Layouts  (destructive — rebuilds windows in session)"
row "prefix L"        "Layout picker menu"
row ""                "  d = Dev (files + harness)    a = AI (files + harness + AI windows)"
row ""                "  f = Focus (one window each)  w = Cowork (files + shell + AI)"
row "aibox start"     "--layout dev|ai|focus|cowork   (sets layout at session start)"

hdr "Themes"
row "prefix T"        "Theme picker menu"
row ""                "  Choose from configured themes or toggle light / dark mode."
row ""                "  R in the menu: heavy restart — kills and respawns TUI panes."

hdr "Sessions"
row "prefix q"        "Kill tmux session (prompt)"    "prefix \$"   "Rename session"
row "prefix ("        "Previous session"              "prefix )"    "Next session"

hdr "Copy mode / scrollback"
row "prefix ["        "Enter copy mode (vi)"          "prefix ]"    "Paste from buffer"
row "v"               "Begin selection (in copy mode) y            Copy selection to clipboard"
row "prefix /"        "Search scrollback"

hdr "aibox helpers"
row "prefix L"        "Layout picker (see Layouts)"   "prefix T"    "Theme picker (see Themes)"
row "prefix R"        "Reload tmux config"            "prefix ?"    "This cheatsheet"
row "prefix z"        "Toggle aibox status mode"

hdr "Vim-tmux navigator (no prefix required)"
row "Ctrl+h/j/k/l"   "Move across panes/vim splits seamlessly"

printf "\n${DIM}  Press q to close.${RESET}\n\n"
