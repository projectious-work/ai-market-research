#!/usr/bin/env bash
# Generated by `aibox apply` - do NOT edit.
# Categorized tmux keybinding reference.  Invoked by: prefix + ?
#
# MAINTENANCE NOTE: this script is a static curated list.  When adding new
# prefix bindings to DEFAULT_TMUX_CONF (cli/src/tmux/status.rs), also add a
# row here so the two stay in sync.  The bind-key -N descriptions are the
# canonical source of truth; this file is the user-visible rendering.

BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'
ACCENT=$'\033[38;5;214m'   # amber - matches aibox default accent
MUTED=$'\033[38;5;244m'

PANE_WIDTH=110
SECTION_WIDTH=100
KEY_WIDTH=21
DESC_WIDTH=29
SEP_WIDTH=$((SECTION_WIDTH - 2))
SEP_TEXT="$(printf "%*s" "$SEP_WIDTH" '' | tr ' ' 'ÔöÇ')"
SEP="${MUTED}${SEP_TEXT}${RESET}"

center_print() {
  # center_print <plain_line> <styled_line>
  local plain="$1"
  local styled="$2"
  if [[ -z "$plain" ]]; then
    printf "\n"
    return
  fi
  local plain_len=${#plain}
  local left=0
  if (( plain_len < PANE_WIDTH )); then
    left=$(( (PANE_WIDTH - plain_len) / 2 ))
  fi
  printf "%*s%s\n" "$left" "" "$styled"
}

paint_box() {
  local title="$1"
  local line_fill
  local title_plain

  line_fill="$(printf "%*s" "$SEP_WIDTH" '' | tr ' ' 'ÔĽÉ')"

  local top="ÔĽö${line_fill}ÔĽŚ"
  local bottom="ÔĽÜ${line_fill}ÔĽŁ"

  title_plain="  ${title}"
  local left_pad=$(( (SECTION_WIDTH - 2 - ${#title_plain}) / 2 ))
  local right_pad=$(( SECTION_WIDTH - 2 - ${#title_plain} - left_pad ))
  [[ $left_pad -lt 0 ]] && left_pad=0
  [[ $right_pad -lt 0 ]] && right_pad=0
  local middle="ÔĽĹ$(printf "%*s" "$left_pad" '')${title_plain}$(printf "%*s" "$right_pad" '')ÔĽĹ"

  center_print "$top" "$top"
  center_print "$middle" "$middle"
  center_print "$bottom" "$bottom"
}

hdr() {
  center_print "" ""
  local heading="$1"
  local plain
  plain=$(printf "  %-*s" "$((SECTION_WIDTH - 2))" "$heading")
  center_print "$plain" "${ACCENT}${BOLD}$plain${RESET}"
  center_print "  ${SEP_TEXT}" "${MUTED}  ${SEP_TEXT}${RESET}"
}

row() {
  # row <key> <desc> [<key2> <desc2>]
  local k1="$1" d1="$2" k2="${3:-}" d2="${4:-}"
  local plain styled

  if [[ -n "$k2" ]]; then
    plain=$(printf "  %-*s  %-*s  %-*s  %s" "$KEY_WIDTH" "$k1" "$DESC_WIDTH" "$d1" "$KEY_WIDTH" "$k2" "$d2")
    styled=$(printf "  ${BOLD}%-*s${RESET}  %-*s  ${BOLD}%-*s${RESET}  %s" "$KEY_WIDTH" "$k1" "$DESC_WIDTH" "$d1" "$KEY_WIDTH" "$k2" "$d2")
  else
    plain=$(printf "  %-*s  %-*s" "$KEY_WIDTH" "$k1" "$DESC_WIDTH" "$d1")
    styled=$(printf "  ${BOLD}%-*s${RESET}  %-*s" "$KEY_WIDTH" "$k1" "$DESC_WIDTH" "$d1")
  fi

  center_print "$plain" "$styled"
}

blank() { echo; }

paint_box "aibox  -  keyboard keybinding reference         (prefix = Ctrl+g)"

hdr "Tmux - Panes"
row "prefix h/j/k/l"       "Navigate pane left/down/up/right"      "prefix r"            "Split pane right"
row "prefix d"             "Split pane down"                       "prefix f / z"        "Zoom pane"
row "prefix x"             "Kill pane"                             "prefix = / -"         "Resize pane (default)"

hdr "Tmux - Windows"
row "prefix c"             "New window"                            "prefix n/p"          "Next / prev window"
row "prefix 1-9"           "Jump to window N"
row "prefix g"             "Jump to lazygit window"                "prefix s"            "Jump to shell window"
 
hdr "Tmux - Session"
row "prefix q"             "Kill tmux session (prompt)"            "prefix $"            "Rename session"
row "prefix ("             "Previous session"                       "prefix )"            "Next session"

hdr "Tmux - Layouts (destructive)"
row "prefix L"             "Layout picker menu"                    "aibox start"         "Preset layout bootstrap"
row "d / a / f / w"       "Dev / AI / Focus / Cowork"             "L (menu mode)"       "One-key layout chooser"

hdr "Tmux - Themes"
row "prefix T"             "Theme picker menu"                     "R in theme menu"     "Restart TUIs after theme change"
row "prefix z"             "Toggle status mode"

hdr "Tmux - Copy / Scrollback"
row "prefix ["             "Enter copy mode (vi)"                   "prefix ]"            "Paste from buffer"
row "v"                   "Begin selection in copy mode"           "y"                   "Copy selection to clipboard"
row "prefix /"            "Search scrollback"

hdr "Yazi - File manager"
row "h/j/k/l"             "Navigate"                              "Enter"               "Edit file in Vim (suspend Yazi)"
row "e"                   "Open in Vim pane"                      "O"                   "Open interactively"
row "Space"               "Select file/entry"                     "q"                   "Quit Yazi"
row "p"                   "Full preview in pane"                  "/"                   "Search files"
row "c p / c d / c f"     "Copy path / dirname / filename"        "w s"                 "Size selected files"
row "g s / g c"           "Git status / git diff"                 "g r"                 "Refresh git index"
row "z h / z l / z m / z c" "Toggle parent/preview/max panes"      "."                   "Toggle hidden files"

hdr "Vim - Editor"
row "Space w"             "Save file"                             "Space q"             "Quit"
row "Space x"             "Save and quit"                         "Space e"             "Open netrw explorer"
row "Space n / Space p"   "Next / previous buffer"                "<C-h/j/k/l>"         "Move split left/down/up/right"
row "y / yy / Y"          "Yank to host clipboard"                "p"                   "Paste"
row "Esc Esc"             "Clear search highlight"

hdr "Helpers / Diagnostics"
row "prefix R"             "Reload tmux config"                    "prefix ?"            "This cheatsheet"

hdr "Vim-tmux navigation (no prefix)"
row "Ctrl+h/j/k/l"         "Move across panes and Vim splits"

center_print "" ""
center_print "  Press q to close." "${DIM}  Press q to close.${RESET}"
