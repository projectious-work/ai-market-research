[core]
    editor = vim
    pager = delta
[init]
    defaultBranch = main
[pull]
    rebase = true
[interactive]
    diffFilter = delta --color-only
[delta]
    syntax-theme = Coldark-Dark
    light = false
    navigate = true
    line-numbers = true
    side-by-side = false
    hunk-header-decoration-style = "#7A8478" box
    file-decoration-style = "#7FBBB3" ul
    minus-style = syntax "#3B1F22"
    minus-emph-style = syntax "#6B1E25"
    plus-style = syntax "#1F3B25"
    plus-emph-style = syntax "#1F5B33"
    zero-style = syntax
[merge]
    conflictStyle = zdiff3

[include]
    path = ~/.config/git/aibox-github.inc
