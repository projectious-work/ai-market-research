#!/usr/bin/env bash
# Generated by `aibox apply` — do NOT edit.
# Switch the current tmux session to a named layout by killing all
# windows in the current session and re-running the layout script in
# `rebuild` mode (which skips the new-session bootstrap).
#
# Usage: aibox-tmux-switch-layout <layout-name>
#
# Layouts live at ~/.config/tmux/layouts/<name>.sh. The script must
# honor the AIBOX_LAYOUT_MODE=rebuild env var the CLI generates: when
# set, it skips its `has-session`/`new-session`/`attach-session` calls
# and only creates the windows.

set -euo pipefail

# Resolve the tmux socket once: callers running this script via `tmux
# run-shell` from inside an attached session inherit `TMUX`, but anyone
# invoking the helper out-of-band (custom `AIBOX_TMUX_SOCKET`, e2e
# drivers, scripted recovery) lands on `/tmp/tmux-$UID/default` by
# default. Override the bare `tmux` command with a function that always
# routes through `-S "$socket"` so the rest of this script stays clean.
# Pre-v0.26.2 the bare calls below silently hit the wrong socket — see
# BACK-20260514-CrispCedar.
socket="${AIBOX_TMUX_SOCKET:-$HOME/.tmux/aibox.sock}"
tmux() { command tmux -S "$socket" "$@"; }

layout="${1:-}"
if [[ -z "$layout" ]]; then
    tmux display-message "aibox-tmux-switch-layout: missing layout name"
    exit 1
fi

script="$HOME/.config/tmux/layouts/${layout}.sh"
if [[ ! -x "$script" ]]; then
    tmux display-message "no such layout: $layout (looked at $script)"
    exit 1
fi

session="$(tmux display-message -p '#S')"
workspace="$(tmux display-message -p '#{session_path}')"

# Step 1 — placeholder window so the session never goes empty.
tmux rename-window -t "${session}:0" "_swap_" 2>/dev/null || true
# Kill every OTHER window. -a means "all except target".
tmux kill-window -a -t "${session}:_swap_" 2>/dev/null || true

# Step 2 — run the layout in rebuild mode.
AIBOX_LAYOUT_MODE=rebuild \
AIBOX_TMUX_SESSION="$session" \
AIBOX_WORKSPACE="$workspace" \
AIBOX_TMUX_SOCKET="$socket" \
    "$script" || {
    tmux display-message "aibox-tmux-switch-layout: $layout failed (see ~/.config/state/aibox-tmux-switch.log)"
    exit 2
}

# Step 3 — drop the placeholder.
tmux kill-window -t "${session}:_swap_" 2>/dev/null || true

# Step 4 — focus the first window of the new layout.
first_window="$(tmux list-windows -t "$session" -F '#W' | head -1)"
[[ -n "$first_window" ]] && tmux select-window -t "${session}:${first_window}"

tmux display-message "switched to ${layout} layout"
