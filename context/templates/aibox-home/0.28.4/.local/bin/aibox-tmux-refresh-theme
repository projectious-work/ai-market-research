#!/usr/bin/env bash
# Generated by `aibox apply` — do NOT edit.
#
# In-session theme refresh.
#
# Tier 1 (default): re-source tmux config; live-reload every shell/Vim/
# Yazi pane via send-keys. Non-destructive — running TUIs in lazygit/
# lnav/ai harness panes will still show old colors until reopened.
#
# Tier 2 (--restart-tuis): kill+respawn every lazygit/lnav/ai-harness
# pane, gated by a Yes/No confirmation menu (skippable via
# AIBOX_THEME_CONFIRM_RESTART_TUIS=false).
#
# Caveat: panes whose `pane_current_command` reads `bash` but actually
# host a remote SSH session will receive the source command as
# literal text on the remote shell. No reliable detection.

set -euo pipefail

restart_tuis=false
[[ "${1:-}" == "--restart-tuis" ]] && restart_tuis=true

# ---------------------------------------------------------------------------
# Guard: must be running inside (or adjacent to) a tmux server.
# ---------------------------------------------------------------------------
if ! command -v tmux >/dev/null 2>&1; then
    printf 'aibox-tmux-refresh-theme: tmux not found\n' >&2
    exit 1
fi

# Route bare `tmux …` calls through the project's configured socket so
# the helper works both from inside a tmux run-shell (TMUX already set)
# and from out-of-band invocations (custom AIBOX_TMUX_SOCKET, e2e
# drivers, manual recovery). See aibox-tmux-switch-layout for the same
# pattern.
socket="${AIBOX_TMUX_SOCKET:-$HOME/.tmux/aibox.sock}"
tmux() { command tmux -S "$socket" "$@"; }

# ---------------------------------------------------------------------------
# Tier 1 step 1 — re-read tmux config so the new PowerKit theme is active.
# ---------------------------------------------------------------------------
tmux source-file ~/.config/tmux/tmux.conf
tmux refresh-client

# ---------------------------------------------------------------------------
# Tier 1 step 2 — iterate every pane in every session and send live-reload
# keys appropriate to whatever is running in that pane.
# ---------------------------------------------------------------------------
# Format: session:window.pane — we use the global pane id (%N) as the target
# to be unambiguous across sessions.
#
# tmux list-panes -a: all sessions, all windows, all panes.
# Fields: #{pane_id} #{pane_current_command}
# ---------------------------------------------------------------------------

refreshed_count=0
tui_panes=()          # pane_ids of lazygit/lnav/ai-harness panes (tier 2)
tui_cmds=()           # original commands for those panes
current_pane_id=""
if [ -n "${TMUX:-}" ]; then
    current_pane_id="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
fi

while IFS=$'\t' read -r pane_id pane_cmd; do
    case "$pane_cmd" in
        bash|zsh|fish|sh)
            # Clear current input line, source the theme env, hit Enter.
            tmux send-keys -t "$pane_id" C-e ''
            tmux send-keys -t "$pane_id" C-u ''
            tmux send-keys -t "$pane_id" '. ~/.config/aibox/theme-env.sh' Enter
            (( refreshed_count += 1 )) || true
            ;;
        vim|nvim)
            # Escape out of any mode, reload the generated aibox colorscheme.
            tmux send-keys -t "$pane_id" Escape ''
            tmux send-keys -t "$pane_id" ':colorscheme aibox' Enter
            (( refreshed_count += 1 )) || true
            ;;
        yazi|ya)
            # Yazi 25.5+ plugin command for theme reload.
            tmux send-keys -t "$pane_id" ':plugin theme-reload' Enter
            (( refreshed_count += 1 )) || true
            ;;
        lazygit|lnav|claude|codex|aider|gemini|opencode|hermes)
            # These need a full restart to pick up new colors (tier 2).
            # Collect them now; act on them only in tier 2.
            tui_panes+=("$pane_id")
            tui_cmds+=("$pane_cmd")
            ;;
        *)
            # Unknown command — skip silently.
            ;;
    esac
done < <(tmux list-panes -a -F $'#{pane_id}\t#{pane_current_command}' 2>/dev/null || true)

# ---------------------------------------------------------------------------
# Tier 1 step 3 — display a tmux message summarising what was done.
# ---------------------------------------------------------------------------
tui_hint_list="lazygit/lnav/<ai-tui>"
if [ "${#tui_panes[@]}" -gt 0 ]; then
    # Build a comma-joined list of the TUI commands for the hint.
    tui_hint_list="$(printf '%s\n' "${tui_cmds[@]}" | sort -u | paste -sd ,)"
fi

tmux display-message "theme: live-refreshed ${refreshed_count} panes; reopen ${tui_hint_list} to apply" 2>/dev/null || true

# ---------------------------------------------------------------------------
# Tier 2 — kill+respawn TUI panes (lazygit / lnav / ai-harness).
# ---------------------------------------------------------------------------
if [[ "$restart_tuis" == "true" ]]; then

    tui_count="${#tui_panes[@]}"

    if [[ "$tui_count" -eq 0 ]]; then
        tmux display-message "theme: restarted 0 TUI panes (none found)" 2>/dev/null || true
        exit 0
    fi

    # -------------------------------------------------------------------
    # Step 5 — optional confirmation guard via display-menu.
    # Skipped when AIBOX_THEME_CONFIRM_RESTART_TUIS=false.
    # -------------------------------------------------------------------
    confirm="${AIBOX_THEME_CONFIRM_RESTART_TUIS:-true}"

    if [[ "$confirm" != "false" ]]; then
        # Build a human-readable summary of the panes that will be restarted.
        # display-menu blocks until the user picks an item.
        # Menu format: "Label" key command ...
        # We use two items: Yes (y) and No (n / q / Escape).
        #
        # Collect a display list like "lazygit(%3), claude(%5)" for the title.
        tui_summary=""
        for i in "${!tui_panes[@]}"; do
            entry="${tui_cmds[$i]}(${tui_panes[$i]})"
            if [[ -z "$tui_summary" ]]; then
                tui_summary="$entry"
            else
                tui_summary="${tui_summary}, ${entry}"
            fi
        done

        # display-menu exits non-zero if the user cancels; treat that as "No".
        confirmed=false
        if tmux display-menu \
                -T "Restart TUI panes? ${tui_summary}" \
                "Yes — restart ${tui_count} pane(s)" y \
                    "run-shell 'touch /tmp/aibox-theme-restart-confirmed-$$'" \
                "No  — skip restart" n "" \
                2>/dev/null; then
            [[ -f "/tmp/aibox-theme-restart-confirmed-$$" ]] && confirmed=true
            rm -f "/tmp/aibox-theme-restart-confirmed-$$"
        fi

        if [[ "$confirmed" != "true" ]]; then
            tmux display-message "theme: TUI restart cancelled" 2>/dev/null || true
            exit 0
        fi
    fi

    # -------------------------------------------------------------------
    # Step 4 — respawn each collected TUI pane, skipping the current pane.
    # -------------------------------------------------------------------
    restarted_count=0
    for i in "${!tui_panes[@]}"; do
        pane_id="${tui_panes[$i]}"
        pane_cmd="${tui_cmds[$i]}"

        # Never yank the pane the user is currently focused on.
        if [[ "$pane_id" == "$current_pane_id" ]]; then
            continue
        fi

        # respawn-pane -k kills the current process and relaunches the shell;
        # we then re-send the original command so the TUI comes back up.
        if tmux respawn-pane -k -t "$pane_id" 2>/dev/null; then
            # Give the shell a moment to settle before re-launching the TUI.
            # We use a short sleep via tmux itself rather than the host shell
            # to avoid depending on sleep being available at the right PATH.
            tmux send-keys -t "$pane_id" "$pane_cmd" Enter
            (( restarted_count += 1 )) || true
        fi
    done

    # -------------------------------------------------------------------
    # Step 6 — final confirmation message.
    # -------------------------------------------------------------------
    tmux display-message "theme: restarted ${restarted_count} TUI panes" 2>/dev/null || true
fi
