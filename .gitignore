# ── Project-specific ─────────────────────────────────────────────────────────
# Add your project-specific ignore patterns here.

# Pre-v0.1.0 hand-off / archival material — kept locally if useful but
# never tracked. Removed from history in the v0.2.2 privacy sweep.
input/

# Release-process privacy markers (per-maintainer, local-only); copy
# from privacy-markers.txt.template and add real markers there.
src/scripts/release/privacy-markers.txt

# Release-evidence artifacts emitted by src/scripts/release/phaseN-*.sh
# (gate evidence files, draft notes, served-HTML captures, etc.)
dist/release-evidence/


